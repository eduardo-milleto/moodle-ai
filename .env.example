# Shared
NODE_ENV=production
DATABASE_URL=postgres://moodle:moodle@db:5432/moodle_ai
APP_BASE_URL=http://localhost:3000
DASHBOARD_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string

# Moodle
MOODLE_BASE_URL=https://moodle.unisinos.br
MOODLE_USERNAME=
MOODLE_PASSWORD=
MOODLE_ICS_URL=

# Worker
SYNC_CRON=0 */6 * * *
SYNC_ON_START=true
NOTIFY_DUE_HOURS=48
AGENT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Caddy, set when DNS points to the VPS
APP_DOMAIN=
ACME_EMAIL=

# Local Hostinger API helper compatibility.
# The real token lives in /Users/eduardomilleto/Documents/env/.env as hostinger_api_nexor.
HOSTINGER_API_TOKEN=

