{
  "name": "moodle-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @moodle-ai/db generate",
    "db:migrate": "pnpm --filter @moodle-ai/db migrate",
    "sync:once": "pnpm --filter worker sync:once"
  },
  "devDependencies": {
    "typescript": "latest"
  }
}

